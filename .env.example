# Diese Werte in Coolify als Environment-Variablen (Secrets) setzen.
# Lokal zum Testen: in .env kopieren (steht in .gitignore).

# Postgres-Passwort (frei wählbar, lang & zufällig)
POSTGRES_PASSWORD=change-me-long-random

# API-Key, den der Executor im Header X-API-Key schickt (lang & zufällig)
API_KEY=change-me-long-random

# Dashboard-Login (HTTP Basic Auth)
DASH_USER=alex
DASH_PASS=change-me
